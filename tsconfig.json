{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["config/**/*", "facilitator/**/*", "server/**/*", "client/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "contracts"]
}
